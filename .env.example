# Database Type (mysql atau sqlite)
DB_TYPE=mysql

# Konfigurasi MySQL (Jika DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pelita
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Konfigurasi SQLite (Jika DB_TYPE=sqlite)
DB_SQLITE_PATH=database/pelita.sqlite

# Remote Database (Cloud Hosting) - Untuk Sinkronisasi
# Tetap gunakan MySQL untuk hosting cloud
REMOTE_DB_HOST=
REMOTE_DB_PORT=3306
REMOTE_DB_NAME=
REMOTE_DB_USER=
REMOTE_DB_PASS=

# GitHub API Configuration (untuk GitHubUpdater)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_ORG=
GITHUB_FETCH_TYPES=commits,releases
GITHUB_POLL_INTERVAL=300
GITHUB_CACHE_TTL=120
GITHUB_PER_PAGE=30

APP_ENV=local
APP_DEBUG=true
BASE_URL=http://localhost/pelita
